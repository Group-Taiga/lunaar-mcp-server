{
  "name": "@lunaar/mcp-server",
  "version": "0.1.0",
  "description": "Model Context Protocol server for the Lunaar Public API — exposes AI rendering, virtual try-on, 3D generation, and more as MCP tools usable from Claude Desktop, Cursor, Windsurf, and any MCP-compatible host.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "lunaar-mcp-server": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "lunaar",
    "ai",
    "virtual-try-on",
    "image-generation",
    "claude",
    "cursor"
  ],
  "homepage": "https://platform.lunaarvision.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Group-Taiga/lunaar-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/Group-Taiga/lunaar-mcp-server/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0"
  }
}
